{
  "name": "jm-trading",
  "version": "1.0.0",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && cross-env NODE_ENV=production electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.jm.trading",
    "productName": "JM Trading",
    "mac": {
      "category": "public.app-category.finance",
      "target": "dmg"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "dotenv": "^17.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "postcss-import": "^16.1.0",
    "vite": "^6.3.1",
    "wait-on": "^8.0.3"
  }
}
